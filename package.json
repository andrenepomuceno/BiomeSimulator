{
  "name": "biome-simulator-frontend",
  "private": true,
  "version": "1.0.6",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:perf:small": "node scripts/headlessProfile.mjs --scenario small --ci",
    "test:perf:medium": "node scripts/headlessProfile.mjs --scenario medium --ci",
    "profile:headless": "node scripts/headlessProfile.mjs",
    "profile:headless:ci": "node scripts/headlessProfile.mjs --ci",
    "profile:cpu:analyze": "node scripts/analyzeCpuProfile.mjs",
    "profile:phase2": "node scripts/headlessProfile.mjs --scenario phase2",
    "capture": "node scripts/captureScenes.mjs --mode all",
    "capture:ingame": "node scripts/captureScenes.mjs --mode ingame",
    "capture:sprites": "node scripts/captureScenes.mjs --mode sprites"
  },
  "dependencies": {
    "@pixi/utils": "^7.4.2",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.4.7",
    "pixi.js": "^7.4.2",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.52.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.4"
  }
}
